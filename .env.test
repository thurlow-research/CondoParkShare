# .env.test — test-suite environment reference (committed; NOT auto-loaded)
#
# This file DOCUMENTS the fallback values that parkshare/settings/test.py
# applies automatically when no .env file is present. It is a reference for
# developers, not a file that is read by the test runner.
#
# How the test bootstrap works (see test.py for the authoritative source):
#
#   1. test.py calls environ.Env.read_env(".env", overwrite=False) first, so
#      a developer's real .env is respected (useful for running tests against
#      a local DB with a different URL).
#   2. os.environ.setdefault() then fills in any variable still absent, using
#      the values below as the authoritative test-safe defaults.
#
# These values are intentionally weak (short keys, no real secrets) and are
# only safe because the test settings module is NEVER loaded in production.
#
# You should NOT need to create a .env file just to run `pytest`. If the test
# suite fails with "ImproperlyConfigured: Set the SECRET_KEY environment
# variable", the most likely cause is that DJANGO_SETTINGS_MODULE is pointing
# at a settings module other than parkshare.settings.test (check pytest.ini).

# Django secret key — deliberately short and recognisably test-only.
SECRET_KEY=test-secret-key-not-for-production-use-only  # pragma: allowlist secret

# PII field encryption — a valid 32-byte url-safe base64 Fernet key.
# Decodes to exactly 32 bytes so base.py's _fernet_key() accepts it without
# the SHA-256 derivation path (which is blocked in non-DEBUG mode).
PII_ENCRYPTION_KEY=dGVzdC1rZXktZG8tbm90LXVzZS1pbi1wcm9kISEhISE=  # pragma: allowlist secret

# Test database — Django's test runner prefixes "test_", creating
# "test_parkshare_test". This avoids any risk of clobbering the dev database
# (parkshare) when no .env is present.
DATABASE_URL=postgres://parkshare@localhost/parkshare_test  # passwordless by design — localhost dev/CI only

# Environment label for audit metrics.
DJANGO_ENV=test

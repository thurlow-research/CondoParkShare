# ---------------------------------------------------------------------------
# CondoParkShare — environment variable template
#
# Copy this file to .env and fill in real values for local dev or production.
# .env is gitignored — never commit the real file.
#
# TESTS DO NOT NEED A .env FILE.
#   parkshare/settings/test.py sets test-safe fallbacks (SECRET_KEY,
#   PII_ENCRYPTION_KEY, DATABASE_URL=parkshare_test, DJANGO_ENV=test) before
#   importing base.py, so the test suite runs clean with no .env present.
#   See .env.test for the values test.py applies when no .env is found.
#
# REQUIRED VARIABLES (the app will not start without these in a real env):
#   SECRET_KEY, PII_ENCRYPTION_KEY, DATABASE_URL
#
# Generate a Django secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Generate a Fernet PII encryption key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ---------------------------------------------------------------------------

SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-50
POSTGRES_DB=parkshare
POSTGRES_USER=parkshare
POSTGRES_PASSWORD=change-me-strong-random-password
DEBUG=False
DATABASE_URL=postgres://parkshare:change-me-strong-random-password@db/parkshare  # pragma: allowlist secret
ALLOWED_HOSTS=condoparkshare.kumajyo.com,condoparkshare.com,ppe.condoparkshare.kumajyo.com,ppe.condoparkshare.com

# Interface-scoped bind for the web container's published :8001 port (ADR-002
# Decision C, CPS#158). Set this to the host's private-segment LAN IP that Nexus
# routes to (e.g. 192.168.1.X). docker-compose publishes "${WEB_BIND_IP}:8001:8000",
# so this confines gunicorn to the private LAN segment instead of the 0.0.0.0
# wildcard — without it, plain HTTP on :8001 is reachable on every interface and
# bypasses TLS termination + security headers at Nexus. REQUIRED in production:
# if left empty, Docker falls back to the 0.0.0.0 wildcard and the gap reopens.
WEB_BIND_IP=192.168.1.X
PII_ENCRYPTION_KEY=change-me-generate-with-python-fernet-generate-key
EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=your-brevo-api-key
DEFAULT_FROM_EMAIL=noreply@parkshare.kumajyo.com
VAPID_PRIVATE_KEY=generate-with-pywebpush
VAPID_PUBLIC_KEY=generate-with-pywebpush
VAPID_ADMIN_EMAIL=admin@parkshare.kumajyo.com

# Nightly pg_dump destination (used by scripts/backup.sh).
# Override to any writable path; default in backup.sh is /mnt/nas/backups/parkshare.
BACKUP_DIR=/mnt/nas/backups/parkshare

# age public key for backup encryption — private key stored off-NAS.
# Generate a keypair with: age-keygen -o backup-key.txt
# The public key is the "Public key:" line printed by age-keygen.
BACKUP_ENCRYPTION_RECIPIENT=age1...

# CF_API_TOKEN — only needed if the condoparkshare.com zone moves to Cloudflare
# and Caddy is configured for DNS-01 challenge. The current setup uses TLS-ALPN-01
# via Caddy on Nexus, so this token is NOT required for normal operation.
# Leave unset unless you are reconfiguring TLS.
#CF_API_TOKEN=your-cloudflare-api-token

# ---------------------------------------------------------------------------
# Audit monitoring (feat/audit-healthcheck — AUDIT-MONITORING-SPEC.md)
# ---------------------------------------------------------------------------

# Deployment environment identifier used as a Prometheus label.
# opus = prod, faberix = ppe.  Must match ^[a-zA-Z0-9._-]{1,64}$.
# Omitting this variable leaves the label as "unknown" (a startup warning is logged).
DJANGO_ENV=prod

# Shared rate-limit cache. Prod operators MUST uncomment this (the docker-compose
# `redis` service provides it); production.py fails fast with ImproperlyConfigured
# if it is unset on prod. Without a shared cache each gunicorn worker keeps its own
# locmem ratelimit counters, so 4 workers ≈ 4× the login/TOTP attempt budget. On PPE
# locmem is accepted by design (#147), so leave this commented there — setup-run.sh
# copies this file to .env verbatim, and an uncommented value would silently enable
# the shared cache on PPE.
#CACHE_URL=redis://redis:6379/1

# Path for the JSONL recovery sink — must be on the audit_logs named volume
# (mounted at /app/logs in docker-compose.yml).  Default is correct for the
# standard compose setup; only override if you change the mount point or run
# outside Docker.
#AUDIT_RECOVERY_LOG=/app/logs/audit-recovery.jsonl

# Liveness status JSONL — one JSON line appended per audit_healthcheck run.
# Must be on the audit_logs volume (same directory as the recovery log) so it
# survives container restarts.  Readable by the audit-exporter sidecar (Phase 2).
#AUDIT_LIVENESS_STATUS=/app/logs/audit-liveness.jsonl

# How often the host cron runs audit_healthcheck (seconds).  Informational for
# the command; the actual schedule is a host cron or systemd timer.
#AUDIT_LIVENESS_INTERVAL_SECONDS=60

# node_exporter textfile-collector directory.  audit_healthcheck writes
# parkshare_audit.prom here atomically.  Must match the
# --collector.textfile.directory flag on the host node_exporter process.
# On opus/faberix the standard path is /var/lib/prometheus/node-exporter/.
#NODE_EXPORTER_TEXTFILE_DIR=/var/lib/prometheus/node-exporter/

# ---------------------------------------------------------------------------
# monitrix integration (ADR-002) — Phase-2 / fallback only; NOT used by the
# recommended MVP textfile ride. Audit gauges ride the existing node_exporter
# :9100 (live UFW rule 9100/tcp ALLOW 192.168.1.7), so no new port/firewall
# rule is opened for MVP. These vars are consumed by the Phase-2 monitrix
# firewall script (scripts/setup_firewall.sh, re-created at Phase 2 per ADR-002
# ratification amendment 2 after PR #96 was closed). Documented here so a fresh
# .env carries them; leave at defaults until the relevant phase is built.
# ---------------------------------------------------------------------------

# Hostname/label for the monitrix monitoring host (single source of scrape).
#MONITRIX_HOST=monitrix

# Allowed source for the monitoring scrape. IPv4 ONLY — monitrix does not scrape
# over IPv6 (ADR-002 ratification amendment 1 drops all IPv6; there is no
# MONITRIX_SCRAPE_SRC_V6). Matches the live single-host /32 convention.
#MONITRIX_SCRAPE_SRC_V4=192.168.1.7/32

# Loki log-shipper outbound port (Phase 2 forensics, ADR-002 Decision F.5).
# Leave EMPTY for MVP — the setup_firewall.sh LOKI_PORT branch stays skipped
# until this is set.
#LOKI_PORT=

# Dedicated audit-metrics exporter port — FALLBACK ONLY (ADR-002 Decision A
# fallback). Used only if the node_exporter textfile collector cannot be
# enabled and a :9108 host-process exporter is stood up instead. Unused under
# the recommended MVP textfile ride.
#AUDIT_METRICS_PORT=9108

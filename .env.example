SECRET_KEY=change-me-in-production
POSTGRES_DB=parkshare
POSTGRES_USER=parkshare
POSTGRES_PASSWORD=change-me-strong-random-password
DEBUG=False
DATABASE_URL=postgres://parkshare:password@db/parkshare
ALLOWED_HOSTS=condoparkshare.kumajyo.com,condoparkshare.com,ppe.condoparkshare.kumajyo.com,ppe.condoparkshare.com
PII_ENCRYPTION_KEY=change-me-generate-with-python-secrets
EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=your-brevo-api-key
DEFAULT_FROM_EMAIL=noreply@parkshare.kumajyo.com
VAPID_PRIVATE_KEY=generate-with-pywebpush
VAPID_PUBLIC_KEY=generate-with-pywebpush
VAPID_ADMIN_EMAIL=admin@parkshare.kumajyo.com
AGENT_SSH_KEY=~/.ssh/opus_parkshare_agent
AGENT_COMPOSE_PATH=/opt/parkshare/docker-compose.yml
AGENT_BACKUP_DIR=/mnt/nas/backups/parkshare
CF_API_TOKEN=your-cloudflare-token
# Audit-recovery log path — must be on the audit_logs named volume (mounted at /app/logs).
# The default (BASE_DIR/logs/audit-recovery.jsonl = /app/logs/audit-recovery.jsonl)
# is correct when docker-compose.yml mounts audit_logs:/app/logs.  Only override if
# you change the mount point or run outside Docker.
#AUDIT_RECOVERY_LOG=/app/logs/audit-recovery.jsonl
# Future: liveness heartbeat file written by the audit pipeline monitor.
#AUDIT_LIVENESS_STATUS=/app/logs/audit-liveness.status

# ── Monitoring / firewall (monitrix integration) ─────────────────────────────
# Port the audit-metrics Prometheus exporter listens on (host-internal only;
# must NOT be routed through the public Caddy reverse-proxy).
AUDIT_METRICS_PORT=9108

# Loki push port on monitrix — TBD; set before running setup_firewall.sh.
# The outbound UFW rule is skipped with a warning while this is blank.
LOKI_PORT=

# IPv4 and IPv6 source subnets for Prometheus scrapes from monitrix.
# These are private LAN values; tighten to /32 (IPv4) or /128 (IPv6) if you
# want to restrict to a single host rather than the whole subnet.
MONITRIX_SCRAPE_SRC_V4=192.168.1.0/24
MONITRIX_SCRAPE_SRC_V6=fd74:a5b1:bbd1:1::/64

# Hostname (or IP) of the monitrix host — used as the outbound Loki destination.
MONITRIX_HOST=monitrix.kumajyo.com

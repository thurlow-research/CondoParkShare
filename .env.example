SECRET_KEY=change-me-in-production
POSTGRES_DB=parkshare
POSTGRES_USER=parkshare
POSTGRES_PASSWORD=change-me-strong-random-password
DEBUG=False
DATABASE_URL=postgres://parkshare:password@db/parkshare
ALLOWED_HOSTS=parkshare.kumajyo.com,parkshare.bellevuetowers.org
PII_ENCRYPTION_KEY=change-me-generate-with-python-secrets

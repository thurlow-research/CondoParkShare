# SMS Pager relay environment file template
#
# The REAL file lives at: /etc/monitrix/sms-pager.env
# Permissions:  chmod 600 /etc/monitrix/sms-pager.env
# Owner:        monitrix-pager (the dedicated unprivileged service user)
#
# DO NOT commit the real file. This example file is the only
# secrets-related file that belongs in the repository.
#
# ── RELAY-ONLY VARS (loaded by sms-pager.service / sms-pager-heartbeat.service) ──
#
# This file is loaded ONLY by the sms-pager.service relay.  It carries Twilio
# credentials and the webhook shared secret.  It must NOT carry SMTP credentials
# — the relay never sends email.  SMTP belongs in grafana.ini [smtp] (see below).
#
# ─── Twilio credentials ────────────────────────────────────────────────────────
# Account SID — from Twilio Console dashboard ("AC…")
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token — from Twilio Console dashboard. Treat like a password.
# Never log this value. Rotate by updating this file + `systemctl restart sms-pager`.
TWILIO_AUTH_TOKEN=your_auth_token_here

# The SMS-capable sender number you purchased in Twilio, E.164 format.
# US local 10DLC or Toll-Free.  Example: +15550001234
TWILIO_FROM=+1XXXXXXXXXX

# ─── Recipient numbers ─────────────────────────────────────────────────────────
# Comma-separated E.164 numbers.  Use >= 2 recipients so a dead phone
# does not silently drop the page.  Example: +15551112222,+15553334444
SMS_RECIPIENTS=+1XXXXXXXXXX,+1YYYYYYYYYY

# ─── Relay network bind ────────────────────────────────────────────────────────
# The relay must bind localhost only; Grafana posts to it over the loopback.
# Do not change RELAY_BIND to 0.0.0.0 — the relay has no auth beyond the
# shared secret and must never be reachable from off-host.
RELAY_BIND=127.0.0.1
RELAY_PORT=9876

# ─── Slow-loris / stalled-client defence ──────────────────────────────────────
# Per-connection socket read deadline in seconds.  Applied to the entire
# inbound side of each request: request-line, headers, AND the body read.
# A client that stops sending for longer than this is dropped and the
# connection closed.  The relay is threaded so a stalled client never blocks
# a concurrent alert delivery.  10s is generous for a local Grafana webhook.
# Raise only if you observe false-positive timeouts in journald.
RELAY_REQUEST_TIMEOUT=10

# ─── Shared secret (Grafana → relay auth) ─────────────────────────────────────
# Grafana passes this in the X-Relay-Secret header on every webhook POST.
# The relay rejects requests that omit or mismatch this value (403).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum length: 32 characters.  The relay will exit(1) on startup if shorter.
WEBHOOK_SHARED_SECRET=change_me_generate_with_secrets_token_urlsafe_32

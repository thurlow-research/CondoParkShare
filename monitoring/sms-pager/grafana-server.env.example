# Grafana-server secrets — safe storage via EnvironmentFile
#
# These vars are loaded by grafana-server.service via an EnvironmentFile pointed
# at a 0600 file owned by the grafana user.  Do NOT use the inline
# `Environment=KEY=value` form in a systemd override — that file is world-readable
# (0644) by default and the secret is exposed to all local users via
# `systemctl cat grafana-server` and `systemctl show grafana-server`.
#
# ── HOW TO CREATE THE SECRETS FILE ───────────────────────────────────────────
#
# 1. Create the file with correct ownership and permissions:
#
#      sudo install -m 0600 -o grafana -g grafana /dev/null /etc/grafana/grafana-pager.env
#
# 2. Fill in the values:
#
#      sudo nano /etc/grafana/grafana-pager.env
#
#    Contents (replace placeholders):
#
#      WEBHOOK_SHARED_SECRET=<paste the same value from /etc/monitrix/sms-pager.env>
#      SMTP_TO=oncall@example.com
#
#    The WEBHOOK_SHARED_SECRET must match the relay's value exactly.
#
# 3. Wire the EnvironmentFile into Grafana's systemd unit:
#
#      sudo systemctl edit grafana-server
#
#    Add ONLY these lines to the override file:
#
#      [Service]
#      EnvironmentFile=/etc/grafana/grafana-pager.env
#
#    Do NOT add inline `Environment=WEBHOOK_SHARED_SECRET=…` lines.
#    Inline Environment= lines are world-readable via `systemctl cat` and
#    `systemctl show` — they are not safe for secrets on multi-user hosts.
#
# 4. Restart Grafana:
#
#      sudo systemctl restart grafana-server
#
# ── SMTP (configured in /etc/grafana/grafana.ini [smtp], NOT in any env file) ─
#
# Grafana reads SMTP credentials from grafana.ini.  Do not put SMTP credentials
# in any systemd EnvironmentFile — use grafana.ini directly:
#
# [smtp]
# enabled = true
# host = smtp.sendgrid.net:587
# user = apikey
# password = <your smtp password>
# from_address = alerts@example.com
# from_name = monitrix
#
# ── CONTENTS OF /etc/grafana/grafana-pager.env ───────────────────────────────
#
# WEBHOOK_SHARED_SECRET=<value matching /etc/monitrix/sms-pager.env>
# SMTP_TO=oncall@example.com
